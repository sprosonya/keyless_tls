{
  "servers": {
    "proxy_addr": "127.0.0.1:443",
    "keyserver_addr": "127.0.0.1:8443",
    "httpserver_addr": "127.0.0.1:8080"
  },
  "certificates": {
    "directory": "certs",
    "web_cert_file": "certs/web.crt",
    "web_key_file": "certs/web.key",
    "web_encrypted_key_file": "certs/encrypted_key.json",
    "proxy_cert_file": "certs/proxy.crt",
    "proxy_key_file": "certs/proxy.key",
    "ca_cert_file": "certs/ca.crt",
    "ca_key_file": "certs/ca.key",
    "keyserver_cert_file": "certs/keyserver.crt",
    "keyserver_key_file": "certs/keyserver.key"
  }
}